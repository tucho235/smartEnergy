# Copiar este archivo a .env y completar con los valores reales.
# El .env NUNCA debe commitearse (está en .gitignore).

# ── Dispositivo Tuya ──────────────────────────────────────────────────────────
# Obtener desde Tuya IoT Platform (iot.tuya.com) → Cloud → Devices
TUYA_DEVICE_ID=your_device_id_here
TUYA_DEVICE_IP=192.168.x.x
TUYA_DEVICE_KEY=your_local_key_here
TUYA_PROTOCOL=3.3

# ── Monitor ───────────────────────────────────────────────────────────────────
MONITOR_INTERVAL=10          # segundos entre lecturas
LOG_CSV=/home/pi/consumo.csv   # vacío para deshabilitar CSV

# ── InfluxDB ──────────────────────────────────────────────────────────────────
INFLUX_HOST=localhost
INFLUX_PORT=8086
INFLUX_DB=tuya

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_URL=http://localhost:3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_grafana_password_here
# UID del datasource InfluxDB — verlo en Grafana → Connections → Data Sources → InfluxDB → URL
GRAFANA_DS_UID=your_datasource_uid_here
